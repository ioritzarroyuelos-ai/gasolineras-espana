# Variables opcionales. Copia a .env (o configura en el dashboard de
# Cloudflare Pages → Settings → Environment variables) segun el entorno.
#
# Ninguna es OBLIGATORIA para arrancar en local. El rate-limit in-memory y la
# validacion zod funcionan sin configuracion.

# ---- Cloudflare Turnstile (anti-bot en /api/ingest) ----
# Registra un site en https://dash.cloudflare.com/?to=/:account/turnstile y
# pega aqui las dos claves. Si faltan, el reto no se exige (modo dev).
#
# La site key (publica) se inyecta al cliente via buildPage().
# La secret key se usa server-side para validar el token.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Cloudflare Web Analytics (opcional, privacy-first, sin cookies) ----
# Genera el token en Analytics → Web Analytics → + Add a site. Si se define,
# shell.ts inyecta el beacon.
CF_WEB_ANALYTICS_TOKEN=

# ---- Dev: URL base para tests E2E ----
# Por defecto los tests usan http://127.0.0.1:8788 (wrangler pages dev).
# Cambialo para correrlos contra un deploy de staging.
E2E_BASE_URL=http://127.0.0.1:8788
