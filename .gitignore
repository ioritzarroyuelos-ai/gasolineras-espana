# prod
dist/

# dev
.yarn/
!.yarn/releases
.vscode/*
!.vscode/launch.json
!.vscode/*.code-snippets
.idea/workspace.xml
.idea/usage.statistics.xml
.idea/shelf

# deps
node_modules/
.wrangler

# Artefactos regenerables de D1 — el backfill sale de `npm run backfill:d1`
# y se puede regenerar cualquier dia; no commiteamos 2-10 MB de SQL
# autogenerado. La migracion canonica 0001_*.sql SI se commitea (es fuente).
migrations/9999_backfill.sql

# sw.js se regenera en prebuild desde scripts/sw.js.tpl (ver scripts/gen-sw.mjs).
# El CACHE_NAME incluye el short SHA del commit para que cada release invalide
# la cache vieja automaticamente sin tocar el template a mano.
public/sw.js

# env
.env
.env.production
.dev.vars

# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# misc
.DS_Store

# tests
.lighthouseci/
playwright-report/
test-results/
tests/e2e/.auth/

# claude code metadata (worktrees, sessions, local-only)
.claude/

# scratch / dev (HTML/PDF descargados manualmente para investigar parsers)
.tmp/

# cache local de geocoding Nominatim — los CI workers llenan su propia cache
# desde cero; solo es util en dev local para evitar ratelimit de Nominatim.
scripts/cache/

# tesseract.js descarga automaticamente el modelo de idioma 'spa' al CWD la
# primera vez que se ejecuta el OCR. No commitear (~10MB) — se regenera.
spa.traineddata
